"end_com_win": "res://dialog/timelines/end_com_win.dtl",
"end_gar_win": "res://dialog/timelines/end_gar_win.dtl",
"test_start": "res://dialog/timelines/test_start.dtl"
}
layout/style_directory={
"": "res://dialog/timelines/timeline_style.tres",
"timeline_style": "res://dialog/timelines/timeline_style.tres"
}
glossary/default_case_sensitive=true
layout/style_list=["res://dialog/timelines/timeline_style.tres"]
layout/default_style="res://dialog/timelines/timeline_style.tres"
variables={
"PlayerName": "test",
"temp_value": ""
}

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

