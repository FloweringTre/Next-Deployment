; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Next-Deployment"
run/main_scene="uid://0amlqx7j12go"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/image="uid://bh7k1tdjkh1u1"
config/icon="res://icon.svg"

[autoload]

Globals="*uid://cusm8xcnuki1a"
BuySheet="*uid://crlb6dpasaq8w"
Dialogic="*uid://ds2q0uclmolvu"
TransitionFade="*uid://cbonh3avqw1k4"

[dialogic]

directories/dch_directory={
"civie": "res://dialog/characters/civie.dch",
"clone": "res://dialog/characters/clone.dch",
"gar": "res://dialog/characters/gar.dch",
"player": "res://dialog/characters/player.dch"
}
directories/dtl_directory={
"end_both_loss": "res://dialog/timelines/end_both_loss.dtl",
